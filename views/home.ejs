<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 30px;
        }

        h3 {
            text-align: center;
        }

        table {
            width: 80%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        table, th, td {
            border: 1px solid #ddd;
        }

        th {
            background-color: #f4f4f4;
            padding: 6px;
        }

        td {
            padding: 5px;
            text-align: center;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        a {
          display: flex;
          justify-content: center;
          text-align: center;
        }
    </style>
</head>
<body>

    <h3>Welcome to URL Shortener Application</h3>

    <table>
        <thead>
            <tr>
                <th>Short ID</th>
                <th>Original URL</th>
                <th>Total Clicks</th>
            </tr>
        </thead>

        <tbody>
            <% url.forEach((item) => { %>
                <tr>
                    <td>http://localhost:8001/url/<%= item.shortId %></td>
                    <td><%= item.redirectUrl %></td>
                    <td><%= item.visitHistory.length %></td>
                </tr>
            <% }) %>
        </tbody>
       
    </table>
    <br><br>

    <a href="/shortner">➕ Create New Short URL</a>
</body>
</html>